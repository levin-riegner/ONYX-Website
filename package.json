{
	"name": "tackl",
	"version": "3.2.3",
	"description": "The ultimate Next.js starter kit!",
	"license": "MIT",
	"engines": {
		"node": ">=24.0.0"
	},
	"author": "joebentaylor1995",
	"repository": {
		"type": "git",
		"url": "https://github.com/12-studio/tackl"
	},
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "next build --webpack",
		"start": "next start",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"type-check": "tsc --noEmit",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"serve": "serve ./out",
		"commit": "node .gitmessage.js",
		"postinstall": "husky",
		"test": "echo \"No tests specified\" && exit 0",
		"lighthouse": "lhci autorun",
		"outdated": "bunx npm-check-updates"
	},
	"dependencies": {
		"@datocms/cda-client": "^0.2.10",
		"@gsap/react": "^2.1.2",
		"@mux/mux-player-react": "^3.11.5",
		"color": "^5.0.3",
		"graphql": "^16.13.1",
		"graphql-tag": "^2.12.6",
		"gsap": "^3.14.2",
		"lenis": "^1.3.19",
		"next": "^16.1.7",
		"picocolors": "^1.1.1",
		"prompts": "^2.4.2",
		"react": "^19.2.4",
		"react-datocms": "^8.0.0",
		"react-dom": "^19.2.4",
		"react-inlinesvg": "^4.2.0",
		"styled-components": "^6.3.11",
		"tar": "^7.5.11",
		"unicornstudio-react": "^2.1.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@lhci/cli": "^0.15.1",
		"@storybook/addon-docs": "^10.3.0",
		"@storybook/addon-links": "^10.3.0",
		"@storybook/addon-onboarding": "^10.3.0",
		"@storybook/addon-themes": "^10.3.0",
		"@storybook/nextjs": "^10.3.0",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"ajv": "^8.18.0",
		"ajv-keywords": "^5.1.0",
		"husky": "^9.1.7",
		"storybook": "^10.3.0",
		"typescript": "5.9.3"
	},
	"husky": {
		"hooks": {
			"pre-commit": "bun run commit"
		}
	}
}
